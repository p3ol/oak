{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "repository": "https://github.com/p3ol/oak.git",
  "scripts": {
    "prepack": "yarn build && yarn lint && yarn tsc && yarn test",
    "lint": "eslint --max-warnings=0 --cache .",
    "test": "vitest run",
    "build": "turbo build",
    "dev": "storybook dev",
    "serve": "yarn dev",
    "p:core": "yarn workspace @oakjs/core",
    "p:react": "yarn workspace @oakjs/react",
    "p:ckeditor": "yarn workspace @oakjs/ckeditor5-build-custom",
    "p:addon-ckeditor": "yarn workspace @oakjs/addon-ckeditor5-react",
    "p:addon-remirror": "yarn workspace @oakjs/addon-remirror",
    "p:theme": "yarn workspace @oakjs/theme",
    "p:strapi": "yarn workspace @oakjs/strapi-plugin"
  },
  "devDependencies": {
    "@ckeditor/ckeditor5-react": "11.2.0",
    "@junipero/core": "3.13.0",
    "@junipero/tailwind-plugin": "3.13.0",
    "@percy/storybook": "10.0.0",
    "@poool/eslint-config": "6.0.0",
    "@poool/eslint-config-react": "6.0.0",
    "@remirror/pm": "3.0.1",
    "@remirror/react": "3.0.3",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-themes": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/fs-extra": "11.0.4",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.62.1",
    "autoprefixer": "10.5.2",
    "ckeditor5": "48.2.0",
    "css-loader": "7.1.4",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-storybook": "10.4.6",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "lerna": "9.0.7",
    "postcss": "8.5.16",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remirror": "3.0.3",
    "sass": "1.101.0",
    "storybook": "10.4.6",
    "tailwindcss": "3.4.19",
    "tsdown": "0.22.3",
    "tsx": "4.23.0",
    "turbo": "2.10.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  },
  "packageManager": "yarn@4.17.0"
}
